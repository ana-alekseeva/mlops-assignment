# Copy to .env and fill in.

# HuggingFace token for model downloads.
HF_TOKEN=

# The model id you actually serve. Must match whatever you pass to vLLM
# via scripts/start_vllm.sh - if you serve an FP8 / AWQ / GPTQ variant,
# the model id here changes accordingly. The agent uses this for its
# chat-completions requests. Aligned to FP8 (iteration 4 serving precision)
# so the agent and server can't drift into a model-not-found 404.
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507-FP8

# Optional: point the agent at any OpenAI-compatible API so you can build and
# debug the Phase 3 graph without a running vLLM. Uncomment and fill in, then
# switch back to the defaults for final prompt tuning and all of Phases 5-6.
# VLLM_BASE_URL=https://api.openai.com/v1
# VLLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Langfuse keys - you'll get these in Phase 4 after creating a project
# in the local Langfuse UI at http://localhost:3001.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# Iteration 5: fraction of traces shipped to Langfuse. Under load the agent's
# single event loop spends real CPU serializing one span per request; sampling
# to 0.1 (~10%) cuts that overhead (and ClickHouse ingestion) with no request
# dropped - only the tracing, not the work. The Langfuse SDK reads this natively.
# Set back to 1.0 for Phase-4 trace inspection where you want every trace.
LANGFUSE_SAMPLE_RATE=0.1
